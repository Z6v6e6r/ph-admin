NODE_ENV=production
PORT=3000
HOST=0.0.0.0
TRUST_PROXY=true

# --- Auth ---
ADMIN_AUTH_ENABLED=true
ADMIN_AUTH_REQUIRE_STAFF_TOKEN=true
ADMIN_AUTH_TTL_HOURS=12
ADMIN_AUTH_SECRET=CHANGE_ME_STRONG_SECRET
ADMIN_AUTH_USERS_JSON=[{"id":"superadmin-1","login":"superadmin","password":"CHANGE_ME_PASSWORD","roles":["SUPER_ADMIN"],"stationIds":[]}]

# --- MongoDB ---
MONGODB_URI=mongodb://147.45.254.160:27017
MONGODB_DB=ph_admin

# --- Support persistence ---
# primary backend (MAX_BOT and all other connectors by default)
SUPPORT_MONGODB_DB=dialog
# отдельный backend для LK web
SUPPORT_WEB_MONGODB_DB=games
# при необходимости можно закрепить MAX_BOT отдельно:
# SUPPORT_MAX_MONGODB_DB=dialog
# SUPPORT_MONGODB_URI=mongodb://147.45.254.160:27017
# SUPPORT_CLIENTS_COLLECTION=support_clients
# SUPPORT_DIALOGS_COLLECTION=support_dialogs
# SUPPORT_MESSAGES_COLLECTION=support_messages
# SUPPORT_RESPONSE_METRICS_COLLECTION=support_response_metrics
# SUPPORT_OUTBOX_COLLECTION=support_outbox

# --- Web push for PWA messenger ---
WEB_PUSH_ENABLED=true
# Generate with: npx web-push generate-vapid-keys
WEB_PUSH_VAPID_PUBLIC_KEY=CHANGE_ME_WEB_PUSH_PUBLIC_KEY
WEB_PUSH_VAPID_PRIVATE_KEY=CHANGE_ME_WEB_PUSH_PRIVATE_KEY
WEB_PUSH_SUBJECT=mailto:support@example.com
WEB_PUSH_CLICK_URL=/
# WEB_PUSH_MONGODB_URI=mongodb://147.45.254.160:27017
# WEB_PUSH_MONGODB_DB=dialog
# WEB_PUSH_SUBSCRIPTIONS_COLLECTION=web_push_subscriptions

# --- Games source ---
GAMES_SOURCE=mongo
GAMES_MONGODB_DB=games
GAMES_MONGODB_COLLECTION=lk_games

# --- Game chats source (separate MongoDB) ---
# Defaults already point to games_chat/chat_messages on MONGODB_URI
GAMES_CHAT_MONGODB_DB=games_chat
GAMES_CHAT_MESSAGES_COLLECTION=chat_messages
GAMES_CHAT_ADMIN_SENDER_NAME=Администратор станции
GAMES_CHAT_ADMIN_SENDER_ROLE=STATION_ADMIN

# --- LK PadelHub source ---
LK_PADELHUB_MODE=mock
# LK_PADELHUB_GAMES_URL=https://...
# LK_PADELHUB_TOURNAMENTS_URL=https://...
# LK_PADELHUB_COMMUNITIES_LIST_URL=https://...
# LK_PADELHUB_COMMUNITY_BY_ID_URL_TEMPLATE=https://.../{id}
# LK_PADELHUB_COMMUNITIES_URL=https://...
# LK_PADELHUB_API_TOKEN=...
# COMMUNITIES_MONGODB_URI=mongodb://...
# COMMUNITIES_MONGODB_DB=games
# COMMUNITIES_MONGODB_COLLECTION=lk_communities
# COMMUNITIES_INVITE_BASE_URL=https://padlhub.ru/community/invite/

# --- Public tournaments / join-flow ---
TOURNAMENTS_PUBLIC_BASE_URL=https://padlhub.su/api/tournaments/public/
TOURNAMENTS_PUBLIC_DIRECTORY_URL=https://padlhub.ru/tournaments
TOURNAMENTS_PUBLIC_REQUIRE_LK_AUTH=true
TOURNAMENTS_PUBLIC_LK_AUTH_URL=https://padlhub.ru/lk_new
TOURNAMENTS_PUBLIC_LK_AUTH_POLL_MS=1500
TOURNAMENTS_PUBLIC_KEYCLOAK_BASE_URL=https://kc.vivacrm.ru
TOURNAMENTS_PUBLIC_KEYCLOAK_REALM=prod
TOURNAMENTS_PUBLIC_TENANT_KEY=iSkq6G
TOURNAMENTS_PUBLIC_AUTH_CLIENT_ID=widget
TOURNAMENTS_PUBLIC_AUTH_CHANNEL=cascade
TOURNAMENTS_PUBLIC_AUTH_TIMEOUT_MS=5000
TOURNAMENTS_PUBLIC_SESSION_COOKIE=ph_tournament_client
# Prefer dedicated secret for public tournament cookies
TOURNAMENTS_PUBLIC_SESSION_SECRET=CHANGE_ME_PUBLIC_TOURNAMENT_SESSION_SECRET
TOURNAMENTS_PUBLIC_SESSION_TTL_DAYS=30

# --- Telegram connector ---
TELEGRAM_DELIVERY_MODE=outbox
TELEGRAM_BOT_TOKEN=CHANGE_ME_BOT_TOKEN
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET
TELEGRAM_INTEGRATION_TOKEN=CHANGE_ME_INTEGRATION_TOKEN
TELEGRAM_STATION_MAPPINGS=[{"key":"yas","stationId":"Yasenevo","stationName":"Ясенево","groupChatId":"-1002248644435"},{"key":"nagat","stationId":"Nagatinskaya","stationName":"Нагатинская","groupChatId":"-1002321881785"},{"key":"nagat_p","stationId":"NagatinskayaP","stationName":"Нагатинская Премиум","groupChatId":"-5056259448"},{"key":"tereh","stationId":"Terehovo","stationName":"Терехово","groupChatId":"-4538138614"},{"key":"kuncev","stationId":"Skolkovo","stationName":"Сколково","groupChatId":"-4521607381"},{"key":"sochi","stationId":"Sochi","stationName":"Сочи","groupChatId":"-1003682319256"},{"key":"seleger","stationId":"seleger","stationName":"Селигерская","groupChatId":"-5124280803"},{"key":"t-sbora","stationId":"care_service","stationName":"Точка сбора","groupChatId":"-1003843984863"}]

# --- Viva CRM ---
# Option A: static admin API token
# VIVA_ADMIN_API_TOKEN=CHANGE_ME_VIVA_TOKEN
# Option B: dynamic token via password grant
VIVA_ADMIN_TOKEN_URL=https://kc.vivacrm.ru/realms/prod/protocol/openid-connect/token
VIVA_ADMIN_CLIENT_ID=React-auth-dev
# VIVA_ADMIN_USERNAME=it@example.com
# VIVA_ADMIN_PASSWORD=CHANGE_ME_VIVA_PASSWORD
