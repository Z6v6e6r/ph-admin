# Public API port inside container
PORT=3000

# Set true when running behind nginx/reverse proxy
TRUST_PROXY=true

# Admin auth
ADMIN_AUTH_ENABLED=true
ADMIN_AUTH_REQUIRE_STAFF_TOKEN=true
ADMIN_AUTH_SECRET=change_me_long_random_secret
ADMIN_AUTH_TTL_HOURS=12
# JSON array
# ADMIN_AUTH_USERS_JSON=[{"id":"superadmin-1","login":"superadmin","password":"change_me_password","roles":["SUPER_ADMIN"],"stationIds":[]}]
ADMIN_AUTH_USERS_JSON=

# MongoDB (messages, threads, settings persistence)
MONGODB_URI=mongodb://147.45.254.160:27017
MONGODB_DB=ph_admin_portal

# Infrastructure endpoints
PHAB_PUBLIC_BASE_URL=https://padlhub.su
TG_BOT_CORE_URL=http://80.78.255.203:2606/zver
NODE_RED_CORE_URL=http://147.45.103.3:1880

# PadelHub source mode: mock|http
LK_PADELHUB_MODE=mock
LK_PADELHUB_GAMES_URL=
LK_PADELHUB_TOURNAMENTS_URL=
LK_PADELHUB_COMMUNITIES_LIST_URL=
LK_PADELHUB_COMMUNITY_BY_ID_URL_TEMPLATE=
LK_PADELHUB_COMMUNITIES_URL=
LK_PADELHUB_API_TOKEN=

# Communities MongoDB source (preferred in production)
COMMUNITIES_MONGODB_URI=
COMMUNITIES_MONGODB_DB=
COMMUNITIES_MONGODB_COLLECTION=
COMMUNITIES_INVITE_BASE_URL=https://padlhub.ru/community/invite/

# Public tournaments
TOURNAMENTS_PUBLIC_BASE_URL=https://padlhub.su/api/tournaments/public/
TOURNAMENTS_PUBLIC_DIRECTORY_URL=https://padlhub.ru/tournaments
TOURNAMENTS_PUBLIC_REQUIRE_LK_AUTH=true
TOURNAMENTS_PUBLIC_LK_AUTH_URL=https://padlhub.ru/lk_new
TOURNAMENTS_PUBLIC_LK_AUTH_POLL_MS=1500
TOURNAMENTS_PUBLIC_KEYCLOAK_BASE_URL=https://kc.vivacrm.ru
TOURNAMENTS_PUBLIC_KEYCLOAK_REALM=prod
TOURNAMENTS_PUBLIC_TENANT_KEY=iSkq6G
TOURNAMENTS_PUBLIC_AUTH_CLIENT_ID=widget
TOURNAMENTS_PUBLIC_AUTH_CHANNEL=cascade
TOURNAMENTS_PUBLIC_AUTH_TIMEOUT_MS=5000
TOURNAMENTS_PUBLIC_SESSION_COOKIE=ph_tournament_client
TOURNAMENTS_PUBLIC_SESSION_SECRET=
TOURNAMENTS_PUBLIC_SESSION_TTL_DAYS=30

# Telegram inbound webhook validation (optional)
TELEGRAM_WEBHOOK_SECRET=

# Telegram station mapping JSON (optional override)
# TELEGRAM_STATION_MAPPINGS=[{"key":"yas","stationId":"Yasenevo","stationName":"Ясенево","groupChatId":"-1002248644435"}]
TELEGRAM_STATION_MAPPINGS=

# Outbound delivery mode: outbox (recommended with Node-RED) | direct
TELEGRAM_DELIVERY_MODE=outbox

# Shared token for Node-RED -> API outbox endpoints
TELEGRAM_INTEGRATION_TOKEN=change_me_strong_token

# Bot token is required if TELEGRAM_DELIVERY_MODE=direct
# For outbox mode keep it empty or fill for future direct fallback
TELEGRAM_BOT_TOKEN=
